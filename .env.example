# ============================================================
# ShopEasy Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to GitHub!
# ============================================================

# Aiven MySQL (get these from your Aiven dashboard)
DB_URL=jdbc:mysql://YOUR_AIVEN_HOST:YOUR_PORT/defaultdb?useSSL=true&requireSSL=true&verifyServerCertificate=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=avnadmin
DB_PASSWORD=YOUR_AIVEN_PASSWORD

# JWT
JWT_SECRET=ShopEasySecretKey2024VeryLongSecretKeyForJWTSigning12345
JWT_EXPIRATION=86400000

# CORS — set to your Netlify URL after frontend deployment
CORS_ORIGINS=http://localhost:3000
